# ==========================================
# Supabase Configuration
# ==========================================
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu_anon_key_publica
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_secreta
SUPABASE_JWT_SECRET=tu_jwt_secret_largo_y_seguro

# ==========================================
# Application Secrets
# ==========================================
AUDIT_HMAC_SECRET=tu_hmac_secret_generado
FIELD_ENCRYPTION_KEY=tu_llave_de_encriptacion_aes256

# ==========================================
# AWS Configuration
# ==========================================
AWS_ACCESS_KEY_ID=tu_aws_access_key
AWS_SECRET_ACCESS_KEY=tu_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=nombre-de-tu-bucket-s3

# ==========================================
# Cloudflare Tunnel (Solo para producción)
# ==========================================
CLOUDFLARE_TUNNEL_TOKEN=tu_token_largo_de_cloudflare_zero_trust
